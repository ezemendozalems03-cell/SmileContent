# Supabase (public/browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only, service role - NEVER expose to the client; used for
# admin invites and any privileged server-side operation)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Content OS"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=content-files

# IA (Asistente con Memoria de Marca) - server-only, se usa en "Generar con IA".
# Crear en https://platform.claude.com > API Keys.
ANTHROPIC_API_KEY=
