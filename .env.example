# Supabase (public/browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only, service role - NEVER expose to the client; used for
# admin invites and any privileged server-side operation)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Content OS"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=content-files

# Reserved for Stage 3 (AI features) - present now so the env shape doesn't
# change later.
OPENAI_API_KEY=
