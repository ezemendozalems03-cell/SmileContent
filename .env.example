# Supabase (public/browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only, service role - NEVER expose to the client; used for
# admin invites and any privileged server-side operation)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Content OS"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=content-files

# IA (Asistente con Memoria de Marca + Motor Estratégico) - server-only.
# AI_PROVIDER elige que servicio se usa: "anthropic" (default), "gemini" u "openai".
# Solo hace falta cargar la API key (y opcionalmente el modelo) del proveedor elegido.
AI_PROVIDER=anthropic

# Anthropic - crear en https://platform.claude.com > API Keys.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini - crear en https://aistudio.google.com/apikey.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3-pro-preview

# OpenAI - crear en https://platform.openai.com/api-keys.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.1

# Blotato (publicación/calendarización automática en redes) - server-only,
# nunca se expone al frontend. Crear en https://my.blotato.com > Settings > API.
BLOTATO_API_KEY=
